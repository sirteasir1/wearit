# ── Google Cloud Virtual Try-On ──────────────────────────────────────
GOOGLE_CLOUD_PROJECT_ID=wearit-498205
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}

# ── Gemini API (for style advice) ────────────────────────────────────
# FREE at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ── Firebase Client ──────────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Firebase Admin (needed for per-user calendar OAuth) ──────────────
# EASIEST: Firebase Console → Project settings (your AUTH project) →
# Service accounts → Generate new private key → paste the WHOLE JSON here:
FIREBASE_ADMIN_KEY=
# …or the three fields individually instead of the JSON above:
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# ── Per-user calendar OAuth (Stylist agent) ──────────────────────────
# Google Calendar: create an OAuth 2.0 Client (Web) in Google Cloud Console,
# enable the Calendar API, and add redirect URIs:
#   http://localhost:3000/api/google/callback  and  https://YOURDOMAIN/api/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Notion: make your integration "Public" at notion.so/my-integrations,
# add redirect URIs:
#   http://localhost:3000/api/notion/callback  and  https://YOURDOMAIN/api/notion/callback
NOTION_OAUTH_CLIENT_ID=
NOTION_OAUTH_CLIENT_SECRET=
# Optional: secret used to sign the OAuth `state` (defaults to the admin key)
OAUTH_STATE_SECRET=
