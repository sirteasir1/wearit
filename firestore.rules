rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read/write their own document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Try-on history — only owner can access
      match /tryons/{tryonId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Wardrobe items — only owner
      match /wardrobe/{itemId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Style Arena live matches — a signed-in player may READ a match they're part
    // of, so the battle syncs in real time via onSnapshot. All writes go through
    // the server (Admin SDK), so client writes stay denied.
    match /arena_matches/{matchId} {
      allow read:  if request.auth != null && request.auth.uid in resource.data.uids;
      allow write: if false;
    }

    // No access to anything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
