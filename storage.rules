rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Users can only read/write their own files
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 10 * 1024 * 1024  // max 10MB
        && request.resource.contentType.matches('image/.*');
    }

    // Battle option images — publicly readable so anyone with the link can
    // vote without an account. Writes happen server-side via the Admin SDK
    // (which bypasses these rules), so direct client writes stay blocked.
    match /battles/{allPaths=**} {
      allow read:  if true;
      allow write: if false;
    }

    // Block everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
